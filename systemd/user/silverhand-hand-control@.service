[Unit]
Description=SilverHand hand control (%i)
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/silver_ws
Environment=ROS_WS=%h/silver_ws
Environment=ROS_DISTRO=jazzy
ExecStart=%h/silver_ws/src/silverhand_hand_control/scripts/start_hand_%i.sh
Restart=on-failure
RestartSec=2
KillSignal=SIGINT
TimeoutStopSec=15

[Install]
WantedBy=default.target
